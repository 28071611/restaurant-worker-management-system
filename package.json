{
  "name": "restaurant-worker-management",
  "version": "1.0.0",
  "description": "Restaurant Worker Management System - MERN Stack",
  "main": "server/index.js",
  "scripts": {
    "start": "node server/index.js",
    "server": "nodemon server/index.js",
    "client": "cd client && npm start",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "seed": "node MONGODB_SEED_SCRIPT_FIXED.js",
    "install-all": "npm install && cd client && npm install"
  },
  "keywords": [
    "restaurant",
    "worker",
    "management",
    "mern",
    "mongodb"
  ],
